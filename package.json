{
  "name": "llamas-remote",
  "version": "1.10.0",
  "description": "Llamas Remote — query selected text and screenshots with local LLMs from the macOS notch; a private chat + notebook.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run watch:renderer\" \"npm run build:ocr && npm run build:main\" \"wait-on dist/panel.js && electron .\"",
    "dev:renderer": "webpack serve --mode development",
    "dev:hot": "concurrently \"npm run watch:renderer\" \"npm run build:ocr && npm run build:main\" \"wait-on dist/panel.js && electron .\"",
    "watch:renderer": "webpack --mode development --watch",
    "build:renderer": "tsc -p tsconfig.renderer.json && webpack --mode development",
    "build:main": "tsc -p tsconfig.main.json",
    "build:ocr": "swiftc -O -target arm64-apple-macos11 build-resources/ocr.swift -o build-resources/.ocr-arm64 && swiftc -O -target x86_64-apple-macos11 build-resources/ocr.swift -o build-resources/.ocr-x64 && lipo -create build-resources/.ocr-arm64 build-resources/.ocr-x64 -output build-resources/ocr && rm -f build-resources/.ocr-arm64 build-resources/.ocr-x64",
    "build": "npm run build:ocr && npm run build:main && npm run build:renderer",
    "build:prod": "npm run build:ocr && npm run build:main && npm run build:renderer:prod",
    "build:renderer:prod": "tsc -p tsconfig.renderer.json && webpack --config webpack.prod.config.js",
    "start": "electron .",
    "package": "npm run build:prod && electron-builder",
    "dist": "npm run build:prod && electron-builder --publish=never",
    "dist:mac": "npm run build:prod && electron-builder --mac",
    "dist:win": "npm run build:prod && electron-builder --win",
    "dist:linux": "npm run build:prod && electron-builder --linux",
    "build:mac": "npm run build:prod && electron-builder --mac --publish=never",
    "release:mac": "npm run build:prod && electron-builder --mac --publish always",
    "build:win": "npm run build:prod && electron-builder --win --publish=never",
    "build:linux": "npm run build:prod && electron-builder --linux --publish=never",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "node scripts/demo.js",
    "setup": "bash scripts/setup.sh",
    "setup:win": "scripts\\setup.bat"
  },
  "keywords": [
    "electron",
    "local-llm",
    "ollama",
    "notch",
    "menubar",
    "notebook",
    "vision",
    "privacy"
  ],
  "author": "Llamas Remote",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danrublop/llamas-remote.git"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.33",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^6.8.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jsdom": "^29.1.1",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7",
    "wait-on": "^7.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@lobehub/icons": "^5.8.0",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-code-block-lowlight": "^3.27.3",
    "@tiptap/extension-color": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-table-cell": "^3.27.3",
    "@tiptap/extension-table-header": "^3.27.3",
    "@tiptap/extension-table-row": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/markdown": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "axios": "^1.13.5",
    "better-sqlite3": "^11.10.0",
    "dompurify": "^3.4.5",
    "electron-updater": "^6.8.9",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.469.0",
    "node-html-parser": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "selection-hook": "^2.0.1"
  },
  "build": {
    "appId": "com.llamasremote.app",
    "productName": "Llamas Remote",
    "directories": {
      "output": "build",
      "buildResources": "build-resources"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "danrublop",
        "repo": "llamas-remote",
        "releaseType": "release"
      }
    ],
    "afterSign": "build-resources/notarize.js",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.map",
      "!**/*.ts",
      "!src/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/selection-hook/**"
    ],
    "extraResources": [
      {
        "from": "build-resources/ocr",
        "to": "ocr"
      },
      {
        "from": "build-resources/trayTemplate.png",
        "to": "trayTemplate.png"
      },
      {
        "from": "build-resources/trayTemplate@2x.png",
        "to": "trayTemplate@2x.png"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build-resources/icon.icns",
      "x64ArchFiles": "Contents/Resources/ocr",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "title": "Llamas Remote"
    }
  }
}
